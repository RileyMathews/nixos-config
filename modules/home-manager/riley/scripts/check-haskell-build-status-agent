#! bash

# This script is designed to be run by LLMs as a fake build command. It waits for ghciwatch to complete its
# reload cycle and then provides the output from the last reload attempt. This allows LLMs to understand
# compilation results, test outcomes, and any errors while getting the benefits of ghciwatch
#
# First run: make ghciwatch warn=true static_ls=1 2>&1 | tee .devel-logs/ghciwatch-output
# Then have the LLM run this script to wait for and display the results.

# Here's what I have in CLAUDE.local.md to use this tool:
# - The project docs are wrong about how to build the projects and run tests. Instead, we have a custom build tool called check_reload_status.sh. When you run this bash tool, it'll build the project and run tests for you. It may take many minutes, but if you time out the first time and call it again it should work
# - Always fix warnings first, then compile errors, then test failures
# - To test changes, use the check_reload_status.sh workflow

set -o errexit
set -o nounset
set -o pipefail

ghciwatch_not_running() {
    echo "ghciwatch is not running. Please stop your work and tell the operator to start ghciwatch."
    exit 1
}

# Check preconditions and tell agent something is wrong if they aren't met
if [[ -f .ghciwatch.pid ]]; then
    if ! ps -o pid= -p "$(cat .ghciwatch.pid)" > /dev/null 2>&1; then
        ghciwatch_not_running
    fi
else
    ghciwatch_not_running
fi

if [[ ! -d .devel-logs ]]; then
    echo "Directory .devel-logs does not exist. Please stop your work and tell the operator to fix the issue."
    exit 1
fi

sleep 1

output_filename=".devel-logs/ghciwatch-output"

show_reload_output() {
    echo "Output from last 'Reloading ghci':"
    last_reload_line=$(grep -n "Reloading ghci" "$output_filename" | tail -n 1 | cut -d: -f1)
    if [ -n "$last_reload_line" ]; then
        tail -n +$last_reload_line "$output_filename"
    else
        echo "No 'Reloading ghci' found, showing last 100 lines:"
        cat "$output_filename"
    fi
}

if [ ! -f "$output_filename" ]; then
    echo "File not found: $output_filename"
    exit 1
fi

timeout=300
elapsed=0

while [ $elapsed -lt $timeout ]; do
    last_line=$(tail -n 1 "$output_filename")

    if echo "$last_line" | rg -q "(• All good! Finished|Reloading failed in|[0-9]+ examples?, [0-9]+ failures?)"; then
        show_reload_output
        exit 0
    fi

    sleep 1
    elapsed=$((elapsed + 1))
done

echo "TIMEOUT: No reload status found after 5 minutes"
exit 2
