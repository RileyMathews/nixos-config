#!/usr/bin/env nix-shell
#! nix-shell -i python
#! nix-shell -p python3

"""
Agent build-status checker for ghciwatch.

Designed to be run by LLMs as a fake build command. Waits for ghciwatch to
complete its reload cycle and then provides the output from the last reload
attempt. This allows LLMs to understand compilation results, test outcomes,
and any errors while getting the benefits of ghciwatch.

First run:  make ghciwatch warn=true static_ls=1 2>&1 | tee .devel-logs/ghciwatch-output
Then have the LLM run this script to wait for and display the results.

Here's what I have in CLAUDE.local.md to use this tool:
- The project docs are wrong about how to build the projects and run tests.
  Instead, we have a custom build tool called check_reload_status.sh. When you
  run this bash tool, it'll build the project and run tests for you. It may
  take many minutes, but if you time out the first time and call it again it
  should work
- Always fix warnings first, then compile errors, then test failures
- To test changes, use the check_reload_status.sh workflow
"""

import doctest
import os
import re
import sys
import time
from pathlib import Path

# ---------------------------------------------------------------------------
# Pattern configuration
#
# Any of these patterns indicate a compilation cycle has started.
# They are checked independently -- any start can lead to any end.
# ---------------------------------------------------------------------------
CYCLE_START_PATTERNS: list[str] = [
    r"Reloading ghci",
    r"Loading ghci",
    r"Adding modules to ghci",
]

# ---------------------------------------------------------------------------
# Any of these patterns indicate a compilation cycle has finished.
# ---------------------------------------------------------------------------
CYCLE_END_PATTERNS: list[str] = [
    r"All good! Finished",
    r"Reloading failed in",
    r"\d+ examples?, \d+ failures?",
]

# ---------------------------------------------------------------------------
# Constants
# ---------------------------------------------------------------------------
OUTPUT_FILE = Path(".devel-logs/ghciwatch-output")
PID_FILE = Path(".ghciwatch.pid")
DEVEL_LOGS_DIR = Path(".devel-logs")
TIMEOUT_SECONDS = 300
POLL_INTERVAL = 1

# Pre-compile regexes for efficiency
_start_regexes = [re.compile(p) for p in CYCLE_START_PATTERNS]
_end_regexes = [re.compile(p) for p in CYCLE_END_PATTERNS]


# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------
def die(message: str, code: int = 1) -> None:
    print(message)
    sys.exit(code)


def ghciwatch_not_running() -> None:
    die("ghciwatch is not running. Please stop your work and tell the operator to start ghciwatch.")


def check_preconditions() -> None:
    """Verify environment is set up correctly before polling."""
    if PID_FILE.exists():
        pid = PID_FILE.read_text().strip()
        try:
            os.kill(int(pid), 0)  # signal 0 = check if process exists
        except (ProcessLookupError, ValueError):
            ghciwatch_not_running()
        except PermissionError:
            pass  # process exists but we can't signal it -- that's fine
    else:
        ghciwatch_not_running()

    if not DEVEL_LOGS_DIR.is_dir():
        die("Directory .devel-logs does not exist. Please stop your work and tell the operator to fix the issue.")

    if not OUTPUT_FILE.is_file():
        die(f"File not found: {OUTPUT_FILE}")


def matches_any(line: str, regexes: list[re.Pattern]) -> bool:
    r"""Return True if the line matches any of the given compiled patterns.

    >>> import re
    >>> pats = [re.compile(r"hello"), re.compile(r"world")]
    >>> matches_any("hello there", pats)
    True
    >>> matches_any("say hello world", pats)
    True
    >>> matches_any("goodbye", pats)
    False
    >>> matches_any("", pats)
    False

    End patterns with numeric groups:
    >>> end_pats = [re.compile(r"All good! Finished"), re.compile(r"\d+ examples?, \d+ failures?")]
    >>> matches_any("All good! Finished in 2.3s", end_pats)
    True
    >>> matches_any("14 examples, 0 failures", end_pats)
    True
    >>> matches_any("1 example, 1 failure", end_pats)
    True
    >>> matches_any("Compiling modules...", end_pats)
    False
    """
    return any(r.search(line) for r in regexes)


def find_last_start_line(lines: list[str], regexes: list[re.Pattern] | None = None) -> int | None:
    """Find the index of the last line matching any start pattern.

    Uses the module-level _start_regexes by default, or accepts custom
    regexes for testing.

    >>> import re
    >>> starts = [re.compile(r"Reloading ghci"), re.compile(r"Loading ghci")]

    Basic case -- finds the last start line:
    >>> find_last_start_line([
    ...     "some noise",
    ...     "Reloading ghci...",
    ...     "error on line 5",
    ...     "Reloading ghci...",
    ...     "All good! Finished",
    ... ], starts)
    3

    Single start line:
    >>> find_last_start_line([
    ...     "Loading ghci...",
    ...     "Compiling Main",
    ...     "All good! Finished",
    ... ], starts)
    0

    No start line found:
    >>> find_last_start_line([
    ...     "some random output",
    ...     "more random output",
    ... ], starts) is None
    True

    Empty input:
    >>> find_last_start_line([], starts) is None
    True

    Handles Loading ghci (new modules added):
    >>> find_last_start_line([
    ...     "Reloading ghci...",
    ...     "error",
    ...     "Loading ghci...",
    ...     "All good! Finished",
    ... ], starts)
    2
    """
    if regexes is None:
        regexes = _start_regexes
    for i in range(len(lines) - 1, -1, -1):
        if matches_any(lines[i], regexes):
            return i
    return None


def show_reload_output() -> None:
    """Print output from the last compilation cycle start to end of file."""
    lines = OUTPUT_FILE.read_text().splitlines()
    start_idx = find_last_start_line(lines)

    if start_idx is not None:
        print("Output from last reload:")
        for line in lines[start_idx:]:
            print(line)
    else:
        print("No reload start pattern found, showing full output:")
        for line in lines:
            print(line)


def poll_for_completion() -> None:
    """Poll the output file until an end pattern appears or timeout."""
    elapsed = 0

    while elapsed < TIMEOUT_SECONDS:
        try:
            last_line = OUTPUT_FILE.read_text().splitlines()[-1]
        except (IndexError, FileNotFoundError):
            time.sleep(POLL_INTERVAL)
            elapsed += POLL_INTERVAL
            continue

        if matches_any(last_line, _end_regexes):
            show_reload_output()
            sys.exit(0)

        time.sleep(POLL_INTERVAL)
        elapsed += POLL_INTERVAL

    die("TIMEOUT: No reload status found after 5 minutes", code=2)


# ---------------------------------------------------------------------------
# Main
# ---------------------------------------------------------------------------
def main() -> None:
    check_preconditions()
    time.sleep(1)  # brief pause to let ghciwatch settle
    poll_for_completion()


if __name__ == "__main__":
    if "--test" in sys.argv:
        results = doctest.testmod(verbose=True)
        sys.exit(0 if results.failed == 0 else 1)
    main()
