#!/usr/bin/env bash

set -euo pipefail

if [[ $# -ne 1 ]]; then
  echo "Usage: $(basename "$0") <directory>" >&2
  exit 1
fi

dir="${1%/}"  # strip trailing slash

if [[ ! -d "$dir" ]]; then
  echo "Error: '$dir' is not a directory" >&2
  exit 1
fi

cd "$dir"
session_name="$(basename "$dir")"

zellij attach "$session_name" --create
