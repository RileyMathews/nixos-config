#!/usr/bin/env bash
set -euo pipefail

# Mirrors the Forgejo repo for the current directory to Codeberg by:
#  1) Deriving repo name from the local git remote (origin)
#  2) Fetching visibility (private/public) from Forgejo
#  3) Failing if the same repo name already exists on Codeberg
#  4) Creating the repo on Codeberg with matching visibility
#  5) Creating a Forgejo *push mirror* to Codeberg that syncs every 8h and on commit
#
# Requirements: bash, git, curl, jq

# ---- hardcoded per your request ----
FORGEJO_HOST="https://git.rileymathews.com"
FORGEJO_USER="riley"
CODEBERG_HOST="https://codeberg.org"
CODEBERG_USER="rileymathews"

# ---- credentials via env vars ----
: "${FORGEJO_TOKEN:?Set FORGEJO_TOKEN in the environment (Forgejo API token)}"
: "${CODEBERG_PASSWORD:?Set CODEBERG_PASSWORD in the environment (Codeberg password)}"

# ---- settings ----
MIRROR_INTERVAL="8h0m0s" # Forgejo/Gitea interval format commonly used for mirrors :contentReference[oaicite:0]{index=0}
SYNC_ON_COMMIT=true

need() { command -v "$1" >/dev/null 2>&1 || { echo "error: missing dependency: $1" >&2; exit 127; }; }
need git
need curl
need jq

die() { echo "error: $*" >&2; exit 1; }

# ---- helpers ----
forgejo_api() { printf "%s/api/v1%s" "$FORGEJO_HOST" "$1"; }
codeberg_api() { printf "%s/api/v1%s" "$CODEBERG_HOST" "$1"; }

curl_json() {
  # curl_json METHOD URL [DATA_JSON] [EXTRA_CURL_ARGS...]
  local method="$1" url="$2" data="${3:-}"
  shift 3 || true

  if [[ -n "$data" ]]; then
    curl -sS -X "$method" "$url" \
      -H 'Accept: application/json' \
      -H 'Content-Type: application/json' \
      "$@" \
      --data "$data"
  else
    curl -sS -X "$method" "$url" \
      -H 'Accept: application/json' \
      "$@"
  fi
}

curl_status() {
  # curl_status METHOD URL [DATA_JSON] [EXTRA_CURL_ARGS...]
  local method="$1" url="$2" data="${3:-}"
  shift 3 || true

  if [[ -n "$data" ]]; then
    curl -sS -o /dev/null -w "%{http_code}" -X "$method" "$url" \
      -H 'Accept: application/json' \
      -H 'Content-Type: application/json' \
      "$@" \
      --data "$data"
  else
    curl -sS -o /dev/null -w "%{http_code}" -X "$method" "$url" \
      -H 'Accept: application/json' \
      "$@" \
      -d ''
  fi
}

# Forgejo token header format :contentReference[oaicite:1]{index=1}
FORGEJO_AUTH_HEADER=( -H "Authorization: token ${FORGEJO_TOKEN}" )

CODEBERG_BASIC_AUTH=( -u "${CODEBERG_USER}:${CODEBERG_PASSWORD}" )

# ---- derive repo from current directory ----
git rev-parse --is-inside-work-tree >/dev/null 2>&1 || die "not inside a git repo"

origin="$(git remote get-url origin 2>/dev/null || true)"
[[ -n "$origin" ]] || die "no 'origin' remote found"

# Normalize and extract "owner/repo" from the origin URL if it points at your Forgejo host.
# Supports:
#   https://git.rileymathews.com/owner/repo(.git)
#   ssh://git@git.rileymathews.com/owner/repo(.git)
#   git@git.rileymathews.com:owner/repo(.git)
host_no_proto="${FORGEJO_HOST#https://}"
host_no_proto="${host_no_proto#http://}"

path=""
case "$origin" in
  "http://"*| "https://"*)
    # e.g. https://git.rileymathews.com/owner/repo.git
    if [[ "$origin" != *"$host_no_proto/"* ]]; then
      die "origin remote does not point at $FORGEJO_HOST (got: $origin)"
    fi
    path="${origin#*${host_no_proto}/}"
    ;;
  "ssh://"*)
    # e.g. ssh://git@git.rileymathews.com/owner/repo.git
    if [[ "$origin" != *"$host_no_proto/"* ]]; then
      die "origin remote does not point at $FORGEJO_HOST (got: $origin)"
    fi
    path="${origin#*${host_no_proto}/}"
    ;;
  *@${host_no_proto}:*)
    # e.g. git@git.rileymathews.com:owner/repo.git
    path="${origin#*@${host_no_proto}:}"
    ;;
  *)
    die "unrecognized origin format (or not pointing at $FORGEJO_HOST): $origin"
    ;;
esac

path="${path%.git}"
owner="${path%%/*}"
repo="${path#*/}"

[[ -n "$owner" && -n "$repo" && "$owner" != "$repo" ]] || die "failed to parse owner/repo from origin: $origin"

echo "Forgejo repo detected: ${owner}/${repo}"

# ---- fetch repo info from Forgejo to match visibility ----
forgejo_repo_tmp="/tmp/forgejo_repo_${owner}_${repo}.json"
forgejo_repo_status="$(
  curl -sS -o "$forgejo_repo_tmp" -w "%{http_code}" \
    -H 'Accept: application/json' \
    "${FORGEJO_AUTH_HEADER[@]}" \
    "$(forgejo_api "/repos/${owner}/${repo}")" || true
)"

[[ "$forgejo_repo_status" == "200" ]] || {
  echo "Forgejo response body:" >&2
  cat "$forgejo_repo_tmp" >&2 || true
  die "failed to read Forgejo repo metadata (HTTP ${forgejo_repo_status})"
}

forgejo_repo_json="$(cat "$forgejo_repo_tmp")"
is_private="$(jq -r 'if .private != null then .private elif .is_private != null then .is_private elif .visibility? == "private" then true elif .visibility? == "public" then false else empty end' <<<"$forgejo_repo_json")"
[[ "$is_private" == "true" || "$is_private" == "false" ]] || {
  echo "Forgejo response body:" >&2
  cat "$forgejo_repo_tmp" >&2 || true
  die "could not determine repo visibility from Forgejo JSON"
}

echo "Forgejo visibility: private=${is_private}"

# ---- check Codeberg for existing repo ----
cb_check_status="$(
  curl -sS -o /dev/null -w "%{http_code}" \
    -H 'Accept: application/json' \
    "${CODEBERG_BASIC_AUTH[@]}" \
    "$(codeberg_api "/repos/${CODEBERG_USER}/${repo}")"
)"

if [[ "$cb_check_status" == "200" ]]; then
  die "Codeberg repo already exists: ${CODEBERG_USER}/${repo}"
elif [[ "$cb_check_status" != "404" ]]; then
  die "unexpected Codeberg status checking repo existence (expected 200 or 404, got ${cb_check_status})"
fi

echo "Codeberg repo does not exist yet: ${CODEBERG_USER}/${repo}"

# ---- create Codeberg repo with matching visibility ----
create_repo_payload="$(jq -cn --arg name "$repo" --argjson private "$is_private" '{name:$name, private:$private}')"

cb_create_status="$(
  curl -sS -o /dev/null -w "%{http_code}" \
    -X POST \
    -H 'Accept: application/json' \
    -H 'Content-Type: application/json' \
    "${CODEBERG_BASIC_AUTH[@]}" \
    --data "$create_repo_payload" \
    "$(codeberg_api "/user/repos")"
)"

if [[ "$cb_create_status" != "201" && "$cb_create_status" != "200" ]]; then
  die "failed to create Codeberg repo (HTTP ${cb_create_status})"
fi

echo "Created Codeberg repo: ${CODEBERG_USER}/${repo}"

# ---- create Forgejo push mirror to Codeberg ----
# Push-mirror options (remote_address/username/password/interval/sync_on_commit) are part of the Gitea/Forgejo API model :contentReference[oaicite:2]{index=2}
remote_address="${CODEBERG_HOST}/${CODEBERG_USER}/${repo}.git"

mirror_payload_with_sync="$(jq -cn \
  --arg remote_address "$remote_address" \
  --arg remote_username "$CODEBERG_USER" \
  --arg remote_password "$CODEBERG_PASSWORD" \
  --arg interval "$MIRROR_INTERVAL" \
  --argjson sync_on_commit "$SYNC_ON_COMMIT" \
  '{remote_address:$remote_address, remote_username:$remote_username, remote_password:$remote_password, interval:$interval, sync_on_commit:$sync_on_commit}'
)"

mirror_endpoint="$(forgejo_api "/repos/${owner}/${repo}/push_mirrors")"

# Try with sync_on_commit first; if the server is too old, retry without it.
mirror_status="$(
  curl -sS -o /tmp/forgejo_mirror_resp.json -w "%{http_code}" \
    -X POST \
    -H 'Accept: application/json' \
    -H 'Content-Type: application/json' \
    "${FORGEJO_AUTH_HEADER[@]}" \
    --data "$mirror_payload_with_sync" \
    "$mirror_endpoint" || true
)"

if [[ "$mirror_status" =~ ^2 ]]; then
  echo "Created Forgejo push mirror to: $remote_address"
else
  # Retry without sync_on_commit (older instances may not accept it)
  mirror_payload_no_sync="$(jq -cn \
    --arg remote_address "$remote_address" \
    --arg remote_username "$CODEBERG_USER" \
    --arg remote_password "$CODEBERG_PASSWORD" \
    --arg interval "$MIRROR_INTERVAL" \
    '{remote_address:$remote_address, remote_username:$remote_username, remote_password:$remote_password, interval:$interval}'
  )"

  mirror_status2="$(
    curl -sS -o /tmp/forgejo_mirror_resp.json -w "%{http_code}" \
      -X POST \
      -H 'Accept: application/json' \
      -H 'Content-Type: application/json' \
      "${FORGEJO_AUTH_HEADER[@]}" \
      --data "$mirror_payload_no_sync" \
      "$mirror_endpoint" || true
  )"

  if [[ "$mirror_status2" =~ ^2 ]]; then
    echo "Created Forgejo push mirror to: $remote_address (without sync_on_commit; your Forgejo may be older)"
  else
    echo "Forgejo response body:" >&2
    cat /tmp/forgejo_mirror_resp.json >&2 || true
    die "failed to create Forgejo push mirror (HTTP ${mirror_status} / retry ${mirror_status2})"
  fi
fi

echo "Done."
echo "Mirror interval: ${MIRROR_INTERVAL}"
echo "Sync-on-push requested: ${SYNC_ON_COMMIT}"
