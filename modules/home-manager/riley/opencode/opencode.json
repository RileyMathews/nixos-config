{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "build",
  "instructions": ["CLAUDE.local.md"],
  "disabled_providers": [
    "github-models",
    "github-copilot",
    "github-copilot-enterprise",
    "amazon-bedrock"
  ],
  "lsp": {
    "haskell-language-server": {
      "command": [],
      "extensions": [
        ".hs"
      ]
    },
    "tsgo": {
      "command": [],
      "extensions": [
        ".ts",
        ".tsx",
        ".js",
        ".jsx"
      ]
    }
  },
  "mcp": {
    "forgejo": {
      "type": "local",
      "command": ["forgejo-mcp", "--url", "https://git.rileymathews.com"],
      "enabled": true
    }
  }
}
